SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SARVAM_API_KEY=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Map animations (optional — video renders without map if not set)
MAPBOX_ACCESS_TOKEN=
# Optional: custom OSRM server for routing (defaults to public demo)
# OSRM_URL=https://router.project-osrm.org/route/v1/driving

# Voiceover — Azure TTS v6 (FREE tier: 500K chars/month, emotional styles)
# Get from: Azure Portal → Create "Speech" resource (F0 = free) → Keys & Endpoint
# Without these, falls back to edge-tts (still free, but no emotions/contours)
# v6: Uses AartiNeural (primary) → SwaraNeural (fallback) → edge-tts (last resort)
# Recommended region: centralindia (closest to users, style-enabled voices available)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# Edge-TTS fallback voice (used when Azure is not configured)
# Options: hi-IN-SwaraNeural (female), hi-IN-MadhurNeural (male)
# EDGE_TTS_VOICE=hi-IN-SwaraNeural

# Avatar video — D-ID API (optional, $18-50/mo for 30-60 videos)
# Get key from https://studio.d-id.com → Settings → API
# Without this key, avatar falls back to static image+audio overlay (free)
# DID_API_KEY=your_base64_encoded_api_key
